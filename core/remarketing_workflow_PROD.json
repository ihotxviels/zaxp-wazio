        },
        {
            "parameters": {
                "jsCode": "const labels = $input.all().map(item => item.json);\nconst instanceName = $node[\"Loop 1 - Instâncias\"].json.name;\nconst normalize = (text) => (text || \"\").replace(/[\\u{1F600}-\\u{1F64F}\\u{1F300}-\\u{1F5FF}\\u{1F680}-\\u{1F6FF}\\u{2600}-\\u{26FF}\\u{2700}-\u{27BF}]/gu, '').toUpperCase().trim();\nconst pagoMeta = labels.filter(l => { const n = normalize(l.name); return n.includes('PAGO') && !n.includes('PENDENTE'); });\nconst pendenteMeta = labels.filter(l => { const n = normalize(l.name); return n.includes('PENDENTE') || n.includes('GERAR') || n.includes('AGUARDANDO'); });\nreturn [{ json: { ...$node[\"Loop 1 - Instâncias\"].json, pago_ids: pagoMeta.map(l => String(l.labelid || l.id || '').split(':').pop()), pago_names: pagoMeta.map(l => l.name), pendente_ids: pendenteMeta.map(l => String(l.labelid || l.id || '').split(':').pop()), pendente_names: pendenteMeta.map(l => l.name) } }];"
            },
            "id": "bfa6ac5c-6549-4019-a7b9-7cda4d6b8ff7",
            "name": "Code - Mapear IDs",
            "type": "n8n-nodes-base.code",
            "typeVersion": 2,
            "position": [
                1340,
                970
            ]
        },
        {
            "parameters": {
                "method": "POST",
                "url": "={{ $node[\"Config Global\"].json.server_url }}/chat/find",
                "sendHeaders": true,
                "headerParameters": {
                    "parameters": [
                        {
                            "name": "token",
                            "value": "={{ $json.token }}"
                        }
                    ]
                },
                "sendBody": true,
                "specifyBody": "json",
                "jsonBody": "{\"operator\": \"AND\", \"sort\": \"-wa_lastMsgTimestamp\", \"limit\": 5000, \"wa_isGroup\": false}",
                "options": {}
            },
            "id": "ae79d61a-b3de-4a12-a3f7-f586a0e82cf9",
            "name": "[HTTP] Busca Chats",
            "type": "n8n-nodes-base.httpRequest",
            "typeVersion": 4.2,
            "position": [
                1540,
                970
            ]
        },
        {
            "parameters": {
                "fieldToSplitOut": "chats",
                "options": {}
            },
            "id": "0f385057-82fd-441c-95e4-b2cda028bfbb",
            "name": "Separar Chats",
            "type": "n8n-nodes-base.splitOut",
            "typeVersion": 1,
            "position": [
                1740,
                970
            ]
        },
        {
            "parameters": {
                "batchSize": 100,
                "options": {}
            },
            "id": "9923df33-824b-4e14-bbdd-c31ee003c619",
            "name": "Loop 2 - Leads",
            "type": "n8n-nodes-base.splitInBatches",
            "typeVersion": 3,
            "position": [
                1940,
                970
            ]
        },
        {
            "parameters": {
                "conditions": {
                    "boolean": [
                        {
                            "value1": "={{ (() => { const meta = $node[\"Code - Mapear IDs\"].json; const chatLabelsRaw = $json.wa_label || []; const chatLabelsNormalized = chatLabelsRaw.map(l => { const val = typeof l === 'object' ? (l.id || l.name || '') : String(l); return val.split(':').pop().toUpperCase(); }); const hasPendente = chatLabelsNormalized.some(l => meta.pendente_ids.includes(l) || meta.pendente_names.some(name => name.includes(l))); const hasPago = chatLabelsNormalized.some(l => meta.pago_ids.includes(l) || meta.pago_names.some(name => name.includes(l))); return hasPendente && !hasPago; })() }}",
                            "value2": true,
                            "operator": "equals"
                        }
                    ]
                },
                "options": {}
            },
            "id": "6d2d2702-0775-4514-96dd-337155026cf2",
            "name": "IF - Só Pendente?",
            "type": "n8n-nodes-base.if",
            "typeVersion": 2,
            "position": [
                2140,
                970
            ]
        },
        {
            "parameters": {
                "operation": "executeQuery",
                "query": "INSERT INTO remarketing_pendentes (instance_name, phone, name)\r\nVALUES ($1, $2, $3)\r\nON CONFLICT (instance_name, phone) \r\nDO UPDATE SET last_interaction = NOW();",
                "options": {
                    "queryReplacement": "={{ [$node[\"Loop 1 - Instâncias\"].json.name, ($json.wa_chatid || $json.owner || \"\").split('@')[0], ($json.name || $json.lead_name || 'Lead')] }}"
                }
            },
