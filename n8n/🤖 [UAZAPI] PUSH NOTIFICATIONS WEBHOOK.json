                8528,
                19232
            ]
        },
        {
            "parameters": {
                "jsCode": "// Usa o pushPayload pronto enviado pelo PHP\n// Não usa mais tokens_destinos (formato antigo) — tudo montado pelo servidor\nconst creds = $input.first().json;\n\nlet payloadStr = creds.pushPayload;\nif (!payloadStr) {\n  throw new Error('pushPayload não encontrado. Verifique se o WAZ.IO está enviando o payload corretamente.');\n}\n\n// Faz parse do JSON para validar\nlet payload;\ntry {\n  payload = JSON.parse(payloadStr);\n} catch(e) {\n  throw new Error('pushPayload inválido: ' + e.message);\n}\n\n// Se include_subscription_ids está vazio, registre um aviso mas NÃO bloqueie\n// (o usuário pode ainda não ter registrado devices via Tokens & Alertas)\nif (!payload.include_subscription_ids || payload.include_subscription_ids.length === 0) {\n  // Retorna resposta de aviso sem chamar OneSignal\n  return [{ json: { ok: false, aviso: 'Nenhum device registrado. Acesse Tokens & Alertas > Gerador de Token e clique em Permitir Notificações.', payload_recebido: payload } }];\n}\n\n// Tudo OK: repassa pushPayload como string para o HTTP Request\nreturn [{\n  json: {\n    REST_API_KEY: creds.REST_API_KEY,\n    pushPayload: payloadStr\n  }\n}];"
            },
            "type": "n8n-nodes-base.code",
            "typeVersion": 2,
            "position": [
